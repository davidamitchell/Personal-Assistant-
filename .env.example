# Environment variables for the Research Assistant.
# Copy this file to .env and fill in the values.
# .env is gitignored – never commit real secrets.

# ── Development bypass ───────────────────────────────────────────────────────
# Set to 1 to skip all authentication during local development.
# Remove or set to 0 before deploying to production.
DEV_AUTH_BYPASS=1

# ── Flask ────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# Port the app listens on (default: 8000)
PORT=8000

# Set to 1 to enable Flask debug mode with auto-reload
FLASK_DEBUG=0

# ── Apple Sign In (production only) ──────────────────────────────────────────
# Register a Services ID at https://developer.apple.com/account/
# and enable Sign In with Apple.
#
# APPLE_CLIENT_ID  – the Services ID bundle identifier (e.g. com.example.researchassistant)
# APPLE_TEAM_ID    – your 10-character Apple Developer Team ID
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
