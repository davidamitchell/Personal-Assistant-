{
  // Base image: Microsoft's Python 3.12 devcontainer image.
  "name": "Personal Assistant",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",

  // Features: Node LTS (for OpenCode + MCP npm packages) and GitHub CLI.
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  // Run install.sh once after the container is created.
  // Sets up the full environment: submodules, uv, Python deps,
  // OpenCode, zsh with oh-my-zsh, shell aliases, and data directories.
  "postCreateCommand": "bash .devcontainer/install.sh",

  // Forward port 8000 and open it automatically in the browser.
  // Only one port is needed – the Flask app serves both the API and the SPA.
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Personal Assistant",
      "onAutoForward": "openBrowser"
    }
  },

  // MCP server configuration for Copilot CLI (GitHub context + filesystem).
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "eamodio.gitlens"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/Personal-Assistant-/.venv/bin/python",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "ms-python.python"
        }
      }
    },
    "codespaces": {
      "openFiles": []
    }
  }
}
